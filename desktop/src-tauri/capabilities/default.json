{
  "$schema": "../gen/schemas/luminus-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "settings"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:event:default",
    "opener:default",
    "fs:default",
    "dialog:default",
    "log:default",
    "sql:default"
  ]
}